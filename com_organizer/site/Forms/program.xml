<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details" label="ORGANIZER_BASIC_PROPERTIES">
        <field name="id" type="hidden"/>
        <field name="organizationIDs" type="OrganizationAssociations" label="ORGANIZER_ORGANIZATION" class="required"
               required="true"/>
        <field name="nomenID" type="GenericOptions" label="ORGANIZER_NOMEN" class="required" required="true"
               table="organizer_nomina" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_NOMEN</option>
        </field>
        <field name="degreeID" type="GenericOptions" label="ORGANIZER_DEGREE" class="required" required="true"
               table="organizer_degrees" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_DEGREE</option>
        </field>
        <field name="accredited" type="integer" label="ORGANIZER_ACCREDITED" class="required" first="1996" last="2096"
               required="true" step="1"/>
        <field name="aTypeID" type="GenericOptions" label="ORGANIZER_ATTENDANCE_TYPE" class="required" default="1" required="true"
               table="organizer_attendance_types" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_ATTENDANCE_TYPE</option>
        </field>
        <field name="campusID" type="Campuses" label="ORGANIZER_CAMPUS" class="required" required="true" city="true">
            <option value="">ORGANIZER_SELECT_CAMPUS</option>
        </field>
        <field name="formID" type="GenericOptions" label="ORGANIZER_PROGRAM_FORM" class="required" default="1" required="true"
               table="organizer_program_forms" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_PROGRAM_FORM</option>
        </field>
        <field name="typeID" type="GenericOptions" label="ORGANIZER_PROGRAM_TYPE" class="required" required="true"
               table="organizer_program_types" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_PROGRAM_TYPE</option>
        </field>
        <field name="focusID" type="GenericOptions" label="ORGANIZER_FOCUS"
               table="organizer_foci" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_FOCUS</option>
        </field>
        <field name="minorID" type="GenericOptions" label="ORGANIZER_MINOR"
               table="organizer_minors" localized="true" textcolumn="name" valuecolumn="id">
            <option value="">ORGANIZER_SELECT_MINOR</option>
        </field>
    </fieldset>
    <fieldset name="de" label="ORGANIZER_SUPPLEMENTAL_PROPERTIES">
        <field name="active" type="list" label="ORGANIZER_ACTIVE" default="1">
            <option value="1">ORGANIZER_ACTIVE</option>
            <option value="0">ORGANIZER_INACTIVE</option>
        </field>
        <field name="categoryID" type="Categories" label="ORGANIZER_CATEGORY">
            <option value="">ORGANIZER_NONE</option>
        </field>
        <field name="description_de" type="editor" label="ORGANIZER_DESC_DE"/>
        <field name="description_en" type="editor" label="ORGANIZER_DESC_EN"/>
        <field name="fee" type="list" label="ORGANIZER_PROGRAM_FEE" default="0">
            <option value="0">ORGANIZER_NO</option>
            <option value="1">ORGANIZER_YES</option>
        </field>
        <field name="frequencyID" type="list" label="ORGANIZER_FREQUENCY" default="3">
            <option value="3">ORGANIZER_AVAILABILITY_SEMESTER</option>
            <option value="5">ORGANIZER_AVAILABILITY_YEAR</option>
            <option value="1">ORGANIZER_AVAILABILITY_SUMMER</option>
            <option value="2">ORGANIZER_AVAILABILITY_WINTER</option>
        </field>
        <field name="nc" type="list" label="ORGANIZER_NC" default="0">
            <option value="0">ORGANIZER_NO</option>
            <option value="1">ORGANIZER_YES</option>
        </field>
        <field name="special" type="list" label="ORGANIZER_PROGRAM_SPECIAL" default="0">
            <option value="0">ORGANIZER_NO</option>
            <option value="1">ORGANIZER_YES</option>
        </field>
    </fieldset>
    <fieldset name="associations" label="ORGANIZER_ASSOCIATIONS" displayinitial="0">
        <field name="subordinates" type="SubOrdinates" label="ORGANIZER_SUBORDINATES"/>
    </fieldset>
</form>